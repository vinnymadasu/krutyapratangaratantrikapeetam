---
layout: base.njk
title: నమోదు నిర్ధారణ | Booking Confirmation - Krutya Pratangira Tantrika Peetam
navPage: payment
permalink: payment.html
needsPaymentConfirm: true
---
<div class="payment-wrap">
  <div class="payment-card">
    <h2>🪷 <span class="te">నమోదు నిర్ధారణ</span><span class="en">Booking Confirmation</span></h2>
    <p class="sub te">మీ వివరాలు విజయవంతంగా నమోదు చేయబడ్డాయి</p>
    <p class="sub en">Your details have been saved successfully</p>

    <div class="summary-box" id="summaryBox">
      <!-- Filled in by JS -->
    </div>

    <!-- QR PAYMENT -->
    <div class="qr-box" id="qrBox">
      <h3><span class="te">QR స్కాన్ చేసి చెల్లించండి</span><span class="en">Scan the QR to Pay</span></h3>
      <img src="images/payment-qr.jpg" alt="Payment QR Code" class="qr-image" onerror="this.replaceWith(Object.assign(document.createElement('div'), {className: 'qr-placeholder', innerHTML: '📱 QR CODE COMING SOON'}))">
      <p class="qr-ref te">మీ నమోదు రిఫరెన్స్: <strong id="qrRefTe"></strong></p>
      <p class="qr-ref en">Your Booking Reference: <strong id="qrRefEn"></strong></p>

      <div class="payment-timer" id="paymentTimer">
        <span class="te">చెల్లింపు నిర్ధారణ ఫారం ఇందులో కనిపిస్తుంది: </span><span class="en">Confirmation form appears in: </span><strong id="timerDisplay">5:00</strong>
      </div>

      <button class="submit-btn payment-done-btn" id="paymentDoneBtn" onclick="revealConfirmForm()">
        <span class="te">✅ చెల్లింపు పూర్తయింది</span>
        <span class="en">✅ Payment Done</span>
      </button>
    </div>

    <!-- PAYMENT CONFIRMATION FORM (hidden until timer/button) -->
    <div class="form-grid confirm-form" id="confirmForm" style="display:none;">
      <h3 class="form-group full" style="margin:0;">
        <span class="te">చెల్లింపు వివరాలు నమోదు చేయండి</span><span class="en">Confirm Your Payment</span>
      </h3>
      <div class="form-group full">
        <label>
          <span class="label-te">UPI ట్రాన్సాక్షన్ / రిఫరెన్స్ నంబర్ *</span>
          <span class="en" style="color:var(--ash);font-size:11px;letter-spacing:0.8px;text-transform:uppercase;">UPI Transaction / Reference Number *</span>
        </label>
        <input type="text" id="transactionRef" placeholder="e.g. 123456789012" required>
      </div>
      <div class="form-group full">
        <label>
          <span class="label-te">చెల్లింపు స్క్రీన్‌షాట్ అప్‌లోడ్ చేయండి *</span>
          <span class="en" style="color:var(--ash);font-size:11px;letter-spacing:0.8px;text-transform:uppercase;">Upload Payment Screenshot *</span>
        </label>
        <input type="file" id="screenshotFile" accept="image/*" required>
      </div>
      <div class="form-group full">
        <label>
          <span class="label-te">గమనికలు (ఐచ్ఛికం)</span>
          <span class="en" style="color:var(--ash);font-size:11px;letter-spacing:0.8px;text-transform:uppercase;">Notes (Optional)</span>
        </label>
        <input type="text" id="confirmNotes" placeholder="ఏదైనా ప్రత్యేక విషయాలు / Any special notes...">
      </div>

      <button class="submit-btn" id="confirmSubmitBtn" onclick="submitPaymentConfirmation()">
        <span class="te">🙏 నిర్ధారణ పంపండి</span>
        <span class="en">🙏 Submit Confirmation</span>
      </button>

      <div class="error-msg" id="confirmErrorMsg"></div>
    </div>

    <div class="success-msg" id="confirmSuccessMsg" style="display:none;">
      ✅ <span class="te">ధన్యవాదాలు! మీ చెల్లింపు నిర్ధారణ అందింది, మా బృందం త్వరలో దీన్ని పరిశీలిస్తుంది.</span>
      <span class="en">Thank you! Your payment confirmation has been received and our team will verify it shortly.</span>
    </div>

    <div class="pending-note">
      <span class="te">💰 ఏవైనా సందేహాలుంటే <strong>📞 6303701032</strong> కి కాల్ చేయండి లేదా <strong>💬 WhatsApp: 9014957203</strong> కి సందేశం పంపండి.</span>
      <span class="en">💰 For any queries, call <strong>📞 6303701032</strong> or message us on <strong>💬 WhatsApp: 9014957203</strong>.</span>
    </div>

    <div class="text-center">
      <a class="back-link" href="index.html">&larr; <span class="te">హోమ్‌కి తిరిగి వెళ్ళండి</span><span class="en">Back to Home</span></a>
    </div>
  </div>
</div>

<script>
  function esc(str) {
    const div = document.createElement('div');
    div.textContent = str == null ? '' : String(str);
    return div.innerHTML;
  }

  (function renderSummary() {
    const raw = sessionStorage.getItem('krutyaBooking');
    const box = document.getElementById('summaryBox');
    if (!raw) {
      box.innerHTML = '<p class="te" style="color:var(--ash);">నమోదు వివరాలు కనబడలేదు. దయచేసి ఫారం మళ్ళీ నింపండి.</p>' +
                      '<p class="en" style="color:var(--ash);">No booking details found. Please fill the form again.</p>';
      return;
    }
    const booking = JSON.parse(raw);

    let rows = '';
    if (booking.booking_ref) {
      rows += `<div class="summary-row"><span class="k">రిఫరెన్స్ / Reference</span><span class="v">${esc(booking.booking_ref)}</span></div>`;
    }
    rows += `<div class="summary-row"><span class="k">పేరు / Name</span><span class="v">${esc(booking.name)}</span></div>`;
    rows += `<div class="summary-row"><span class="k">మొబైల్ / Phone</span><span class="v">${esc(booking.phone)}</span></div>`;
    if (booking.city) {
      rows += `<div class="summary-row"><span class="k">ఊరు / City</span><span class="v">${esc(booking.city)}</span></div>`;
    }
    rows += `<div class="summary-row"><span class="k">పాల్గొనే విధానం / Participation</span><span class="v">${esc(booking.participation_type)}</span></div>`;

    if (booking.services && booking.services.length) {
      const names = booking.services.map(s => (document.body.className === 'lang-en' ? s.name_en : s.name_te)).join(', ');
      rows += `<div class="summary-row"><span class="k">అదనపు సేవలు / Extra Sevas</span><span class="v">${esc(names)}</span></div>`;
    }
    if (booking.notes) {
      rows += `<div class="summary-row"><span class="k">గమనికలు / Notes</span><span class="v">${esc(booking.notes)}</span></div>`;
    }
    rows += `<div class="summary-row total-row"><span class="k">మొత్తం / Total Amount</span><span class="v">₹${Number(booking.total_amount).toLocaleString('en-IN')}/-</span></div>`;

    box.innerHTML = rows;
  })();
</script>
