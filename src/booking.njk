      <p class="sub en">Please fill in your details to register</p>

      <div class="form-grid" id="bookingForm">
        <div class="form-group">
          <label>
            <span class="label-te">మీ పేరు *</span>
            <span class="en" style="color:var(--ash);font-size:11px;letter-spacing:0.8px;text-transform:uppercase;">Full Name *</span>
          </label>
          <input type="text" id="name" placeholder="పేరు నమోదు చేయండి / Enter name" required>
        </div>
        <div class="form-group">
          <label>
            <span class="label-te">మొబైల్ నంబర్ *</span>
            <span class="en" style="color:var(--ash);font-size:11px;letter-spacing:0.8px;text-transform:uppercase;">Mobile Number *</span>
          </label>
          <input type="tel" id="phone" placeholder="10 అంకెలు / 10 digits" maxlength="10" required>
        </div>
        <div class="form-group">
          <label>
            <span class="label-te">మీ ఊరు / నగరం</span>
            <span class="en" style="color:var(--ash);font-size:11px;letter-spacing:0.8px;text-transform:uppercase;">City / Town</span>
          </label>
          <input type="text" id="city" placeholder="City">
        </div>
        <div class="form-group">
          <label>
            <span class="label-te">పాల్గొనే విధానం</span>
            <span class="en" style="color:var(--ash);font-size:11px;letter-spacing:0.8px;text-transform:uppercase;">Participation Type</span>
          </label>
          <select id="participationType" onchange="calcTotal()">
            <option value="full" data-price="10000">10 రోజులు పూర్తి దీక్ష – ₹10,000 / Full 10-day Diksha</option>
            <option value="partial" data-price="0">సేవలు మాత్రమే / Only Specific Sevas</option>
          </select>
        </div>

        <div style="grid-column:1/-1;">
          <label style="color:var(--bright-gold); font-family:'Noto Serif Telugu'; font-size:14px; text-transform:none; letter-spacing:0; opacity:1;">
            <span class="te">⬜ అదనపు సేవలు ఎంచుకోండి (ఐచ్ఛికం)</span>
            <span class="en">⬜ Select Additional Sevas (Optional)</span>
          </label>
        </div>
        <div class="services-checkboxes">
          <label class="checkbox-item">
            <input type="checkbox" value="5116" data-te="అలంకరణ సేవ (1 రోజు)" data-en="Decoration Seva (1 day)" onchange="calcTotal()">
            <div class="item-info">
              <span class="item-te">అలంకరణ సేవ (1 రోజు)</span>
              <span class="en" style="color:#ccc;font-size:11px;display:block;">Decoration Seva (1 day)</span>
              <span class="item-price">₹5,116</span>
            </div>
          </label>
          <label class="checkbox-item">
            <input type="checkbox" value="3116" data-te="ఉదయం లక్ష్మీ వారాహి హోమం" data-en="Morning Lakshmi Varahi Homam" onchange="calcTotal()">
            <div class="item-info">
              <span class="item-te">ఉదయం లక్ష్మీ వారాహి హోమం</span>
              <span class="en" style="color:#ccc;font-size:11px;display:block;">Morning Lakshmi Varahi Homam</span>
              <span class="item-price">₹3,116</span>
            </div>
          </label>
          <label class="checkbox-item">
            <input type="checkbox" value="3116" data-te="సాయంత్రం దశ మహా విద్య హోమం" data-en="Evening Dasha Maha Vidya Homam" onchange="calcTotal()">
            <div class="item-info">
              <span class="item-te">సాయంత్రం దశ మహా విద్య హోమం</span>
              <span class="en" style="color:#ccc;font-size:11px;display:block;">Evening Dasha Maha Vidya Homam</span>
              <span class="item-price">₹3,116</span>
            </div>
          </label>
          <label class="checkbox-item">
            <input type="checkbox" value="15000" data-te="నిత్య అన్నదానం (1 రోజు)" data-en="Nitya Annadanam (1 day)" onchange="calcTotal()">
            <div class="item-info">
              <span class="item-te">నిత్య అన్నదానం (1 రోజు)</span>
              <span class="en" style="color:#ccc;font-size:11px;display:block;">Nitya Annadanam (1 day)</span>
              <span class="item-price">₹15,000</span>
            </div>
          </label>
          <label class="checkbox-item">
            <input type="checkbox" value="1116" data-te="నిత్య పల్లకి సేవ (1 రోజు)" data-en="Nitya Pallaki Seva (1 day)" onchange="calcTotal()">
