              <span class="item-te">నిత్య పల్లకి సేవ (1 రోజు)</span>
              <span class="en" style="color:#ccc;font-size:11px;display:block;">Nitya Pallaki Seva (1 day)</span>
              <span class="item-price">₹1,116</span>
            </div>
          </label>
          <label class="checkbox-item">
            <input type="checkbox" value="51000" data-te="రథోత్సవం (కిరాత వారాహి రోజు)" data-en="Rathotsavam (Kirata Varahi Day)" onchange="calcTotal()">
            <div class="item-info">
              <span class="item-te">రథోత్సవం (కిరాత వారాహి రోజు)</span>
              <span class="en" style="color:#ccc;font-size:11px;display:block;">Rathotsavam (Kirata Varahi Day)</span>
              <span class="item-price">₹51,000</span>
            </div>
          </label>
        </div>

        <div class="amount-summary">
          <span class="label-te">మొత్తం / Total Amount:</span>
          <span class="total" id="totalAmount">₹10,000</span>
