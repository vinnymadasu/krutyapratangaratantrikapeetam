---
layout: base.njk
title: సేవలు & రుసుములు | Services & Charges - Krutya Pratangira Tantrika Peetam
navPage: services
permalink: services.html
---
<main>

  <!-- SERVICES -->
  <section>
    <div class="section-header">
      <div class="section-icon">🌺</div>
      <div class="section-heading">
        <span class="te">అమ్మవారి సేవలు మరియు రుసుములు</span>
        <span class="en">Services & Charges</span>
        <span class="en" style="font-size:12px;color:var(--text-mid);letter-spacing:1px;text-transform:uppercase;">SEVA DETAILS</span>
      </div>
      <div class="section-rule"></div>
    </div>

    <div class="services-grid">
      {% for service in services %}
      <a href="{{ service.slug }}.html" class="service-card-link{% if service.featured %} featured{% endif %}">
        <div class="service-card{% if service.featured %} featured{% endif %}">
          <div class="price">₹{{ service.price | inr }}/- <span>{{ service.unitTe }}</span></div>
          <div class="name-te">{{ service.nameTe }}</div>
          <div class="name-en">{{ service.nameEn }}</div>
          <div class="tag {{ service.tagClass }}">{{ service.tagTe }}</div>
        </div>
      </a>
      {% endfor %}
    </div>
  </section>

  <!-- PARTICIPATION RULES -->
  <section>
    <div class="section-header">
      <div class="section-icon">📋</div>
      <div class="section-heading">
        <span class="te">పాల్గొనే నియమాలు</span>
        <span class="en">Participation Guidelines</span>
      </div>
      <div class="section-rule"></div>
    </div>

    <div class="rules-grid">
      <div class="rule-card">
        <div class="rule-icon">💼</div>
        <p class="te"><strong>ఉద్యోగ/వ్యాపారస్తులకు:</strong> ఉద్యోగం, వ్యాపారం లేదా ఇతర బాధ్యతలు ఉన్న వారు రోజుకు ఒక పూట పూజలో పాల్గొనవచ్చు.</p>
        <p class="en"><strong>For Working Devotees:</strong> Those with jobs or business commitments may participate in one session per day.</p>
      </div>
      <div class="rule-card">
        <div class="rule-icon">🙏</div>
        <p class="te"><strong>పూర్తి సమయం ఉన్న వారికి:</strong> ఉద్యోగ, వ్యాపార బాధ్యతలు లేని వారు రోజుకు మూడు పూటలా పూజలో పాల్గొనవచ్చు.</p>
        <p class="en"><strong>For Full-Time Devotees:</strong> Devotees without job/business commitments may participate in all three sessions daily.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section>
    <div class="booking-section text-center">
      <h2>🪷 <span class="te">మీ సేవను ఇప్పుడే నమోదు చేసుకోండి</span><span class="en">Book Your Seva Today</span></h2>
      <a href="booking.html" class="submit-btn btn-cta-link">
        <span class="te">🙏 సేవ నమోదు చేయండి</span>
        <span class="en">🙏 Register for Seva</span>
      </a>
    </div>
  </section>

</main>
